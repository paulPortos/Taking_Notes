<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/light_bg"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HomeActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="675dp"
        android:background="@color/light_bg"
        app:layout_constraintBottom_toBottomOf="@+id/coordinatorLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topAppBar"
            style="@style/Widget.MaterialComponents.Toolbar.Primary"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/light_bg"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            app:menu="@menu/top_menu"
            app:title="Taking Notes"
            app:titleTextAppearance="@style/TextAppearance.AppCompat.Large"
            app:titleTextColor="@color/black" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinatorLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.bottomappbar.BottomAppBar
            android:id="@+id/bottomAppBar"
            android:layout_width="match_parent"
            android:layout_height="67dp"
            android:layout_gravity="bottom"
            app:backgroundTint="#E9E9E9"
            app:fabAlignmentMode="end"
            app:fabCradleMargin="10dp"
            app:fabCradleRoundedCornerRadius="10dp"
            app:fabCradleVerticalOffset="10dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:orientation="horizontal">


                <ImageButton
                    android:id="@+id/btnhome"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="37dp"
                    android:layout_marginBottom="10dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="Home"
                    android:focusable="true"
                    android:scaleType="fitStart"
                    android:src="@drawable/btn_home" />

                <ImageButton
                    android:id="@+id/btntask"
                    android:layout_width="28dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="70dp"
                    android:layout_marginBottom="10dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="Task"
                    android:focusable="true"
                    android:scaleType="fitStart"
                    android:src="@drawable/btn_task" />

                <ImageButton
                    android:id="@+id/btnflashcards"
                    android:layout_width="30dp"
                    android:layout_height="35dp"
                    android:layout_marginStart="68dp"
                    android:layout_marginBottom="10dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="FlashCards"
                    android:focusable="true"
                    android:scaleType="fitStart"
                    android:src="@drawable/btn_flashcards" />

            </LinearLayout>

        </com.google.android.material.bottomappbar.BottomAppBar>

        <LinearLayout
            android:layout_width="295dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="19dp"
            android:layout_marginBottom="5dp"
            android:orientation="horizontal"
            app:layout_anchor="@+id/bottomAppBar"
            app:layout_anchorGravity="start|bottom">

            <TextView
                android:id="@+id/tvhome"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:layout_weight="1"
                android:text="Home"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/tvtask"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Task"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/tvflashcards"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="FlashCards"
                android:textAlignment="center" />
        </LinearLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:contentDescription="Add"
            android:focusable="true"
            android:src="@drawable/btn_add"
            app:backgroundTint="#ADACAC"
            app:layout_anchor="@id/bottomAppBar"
            app:maxImageSize="45dp" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>


</androidx.constraintlayout.widget.ConstraintLayout>